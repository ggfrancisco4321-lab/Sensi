<!DOCTYPE html><html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sensi Free Fire</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #0f172a;
      color: white;
      text-align: center;
      padding: 20px;
    }
    .card {
      background: #1e293b;
      border-radius: 15px;
      padding: 20px;
      max-width: 400px;
      margin: auto;
      box-shadow: 0 0 15px rgba(0,0,0,0.5);
    }
    h1 {
      color: #38bdf8;
    }
    button {
      background: #22c55e;
      border: none;
      padding: 10px 20px;
      border-radius: 10px;
      color: white;
      font-size: 16px;
      cursor: pointer;
      margin-top: 15px;
    }
    button:hover {
      background: #16a34a;
    }
  </style>
</head>
<body>
  <div class="card">
    <h1>Sensi Braba 🔥</h1>
    <p><strong>Geral:</strong> 95</p>
    <p><strong>Red Dot:</strong> 90</p>
    <p><strong>Mira 2x:</strong> 85</p>
    <p><strong>Mira 4x:</strong> 75</p>
    <p><strong>AWM:</strong> 60</p>
    <p><strong>Olhadinha:</strong> 85</p><button onclick="copiar()">Copiar Sensi</button>

  </div>  <script>
    function copiar() {
      const texto = `Sensi Free Fire:\nGeral: 95\nRed Dot: 90\nMira 2x: 85\nMira 4x: 75\nAWM: 60\nOlhadinha: 85`;
      navigator.clipboard.writeText(texto);
      alert("Sensi copiada!");
    }
  </script></body>
</html>
